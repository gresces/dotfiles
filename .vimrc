set number
set relativenumber

syntax on
colorscheme desert

set cul

"  mouse
set mouse=a
set selection=exclusive
set selectmode=mouse,key

" match
set showmatch

" 256color
set t_Co=256

" file indent
filetype indent on
set autoindent

" position
set textwidth=80
set wrap
set wrapmargin=4
set laststatus=2
set ruler

" scroll
set scrolloff=7
